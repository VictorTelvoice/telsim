{
  "version": 3,
  "routes": [
    {
      "src": "^/index\\.html$",
      "headers": {
        "Cache-Control": "no-store, max-age=0"
      },
      "continue": true
    },
    {
      "src": "^/sw\\.js$",
      "headers": {
        "Cache-Control": "no-store, max-age=0"
      },
      "continue": true
    },
    {
      "src": "^/manifest\\.json$",
      "headers": {
        "Cache-Control": "no-store, max-age=0"
      },
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^/api(/.*)?$",
      "status": 404
    },
    {
      "handle": "error"
    },
    {
      "status": 404,
      "src": "^(?!/api).*$",
      "dest": "/404.html"
    },
    {
      "handle": "miss"
    },
    {
      "src": "^/api/(.+)(?:\\.(?:ts))$",
      "dest": "/api/$1",
      "check": true
    }
  ],
  "framework": {
    "version": "6.4.1"
  },
  "crons": []
}
